        "max": 1,
        "step": 0.01
      },
      {
        "id": "param3",
        "name": "Luma Gamma",
        "default": 0.5,
        "min": 0,
        "max": 1,
        "step": 0.01
      },
      {
        "id": "param4",
        "name": "Original Blend",
        "default": 0.1,
