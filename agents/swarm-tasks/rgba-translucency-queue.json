{
  "version": "1.0",
  "created": "2026-05-17",
  "description": "RGB→Alpha translucency upgrade swarm: 16 RGB-split shaders + 8 new generative shaders",
  "batch_size": 4,
  "wolfram_math": {
    "fresnel_f0_n1_5": 0.04,
    "gaussian_sigma_0_5": "exp(-dist*dist / 0.5)",
    "beer_lambert_density_0_3": "exp(-0.3 * distance)",
    "tent_alpha_curve": "smoothstep(0.0, 0.4, x) * (1.0 - smoothstep(0.4, 1.0, x))",
    "spectral_approximation": "wavelength_to_rgb uses 3-segment linear approximation: 380-500nm=blue->cyan, 500-600nm=green->yellow, 600-780nm=orange->red"
  },
