{
  "id": "vhs-tracking",
  "name": "VHS Tracking Error",
  "url": "shaders/vhs-tracking.wgsl",
  "features": [
    "mouse-driven",
    "upgraded-rgba",
    "audio-reactive",
    "depth-aware"
  ],
  "description": "Simulates VCR tracking errors with scanline tearing and chromatic aberration.",
  "params": [
    {
      "name": "Tracking Error",
      "id": "zoomParam1",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "name": "Noise Level",
      "id": "zoomParam2",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "name": "Color Drift",
      "id": "zoomParam3",
      "default": 0.2,
      "min": 0,
      "max": 1
    },
    {
      "name": "Scanlines",
      "id": "zoomParam4",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
