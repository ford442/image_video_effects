{
  "id": "ripple-bloom",
  "name": "Ripple Bloom",
  "url": "shaders/ripple-bloom.wgsl",
  "category": "hybrid",
  "description": "Combines mouse-driven ripples with audio-reactive bloom. Feels alive and musical, especially on video sources.",
  "tags": ["ripple", "bloom", "hybrid", "audio-reactive", "mouse-driven", "organic"],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "semantic-alpha"
  ],
  "params": [
    {
      "id": "rippleAmount",
      "name": "Ripple Amount",
      "default": 0.7,
      "min": 0.0,
      "max": 1.6,
      "step": 0.01,
      "param": "zoom_params.x"
    },
    {
      "id": "bloomAmount",
      "name": "Bloom Amount",
      "default": 0.75,
      "min": 0.0,
      "max": 1.8,
      "step": 0.01,
      "param": "zoom_params.y"
    },
    {
      "id": "mouseInfluence",
      "name": "Mouse Influence",
      "default": 0.65,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "param": "zoom_params.z"
    },
    {
      "id": "colorShift",
      "name": "Color Shift",
      "default": 0.4,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "param": "zoom_params.w"
    }
  ]
}