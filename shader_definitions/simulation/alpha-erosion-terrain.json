    { "id": "erosionRate", "name": "Erosion Rate", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "depositionRate", "name": "Deposition Rate", "type": "float", "default": 0.4, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "sedimentCapacity", "name": "Sediment Capacity", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 }
