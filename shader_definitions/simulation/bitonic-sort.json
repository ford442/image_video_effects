{
  "id": "bitonic-sort",
  "name": "Bitonic Pixel Sort",
  "url": "shaders/bitonic-sort.wgsl",
  "category": "simulation",
  "description": "Workgroup bitonic pixel sort with FBM-enhanced sort keys, bass-reactive mixing, and semantic luminance-key alpha.",
  "features": [
    "upgraded-rgba",
    "depth-aware",
    "audio-reactive",
    "mouse-driven",
    "multi-ripple"
  ],
  "tags": [
    "simulation",
    "filter",
    "glitch",
    "algorithmic",
    "sort",
    "noise"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Sort Mix",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "param2",
      "name": "Noise Mix",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "param3",
      "name": "Sort Direction",
      "default": 0.0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "labels": ["Ascending", "Descending"]
    },
    {
      "id": "param4",
      "name": "Noise Octaves",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ]
}
