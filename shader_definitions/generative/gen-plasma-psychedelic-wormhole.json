    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven",
    "procedural"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "wormhole",
    "tunnel",
    "plasma",
    "rainbow",
    "cosmic",
    "generative",
    "blackbody",
    "physics"
  ],
