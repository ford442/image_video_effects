{
  "id": "gen-verlet-cloth-wind",
  "name": "Verlet Cloth Wind",
  "url": "shaders/gen-verlet-cloth-wind.wgsl",
  "description": "Verlet integration cloth simulation with wind forces, silk/fabric shading, anisotropic specular highlights, and audio-reactive gusts.",
  "features": [
    "aces-tone-map",
    "audio-reactive",
    "chromatic-aberration",
    "depth-aware",
    "generative",
    "mouse-driven",
    "temporal",
    "upgraded-rgba"
  ],
  "tags": [
    "procedural",
    "generative",
    "cloth",
    "physics",
    "fabric",
    "wind",
    "simulation",
    "audio-reactive"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Wind Strength",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Fabric Weight",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Stiffness",
      "default": 0.55,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Sheen",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
