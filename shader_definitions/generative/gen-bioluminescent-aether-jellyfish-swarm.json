{
  "id": "gen-bioluminescent-aether-jellyfish-swarm",
  "name": "Bioluminescent Aether-Jellyfish Swarm",
  "url": "shaders/gen-bioluminescent-aether-jellyfish-swarm.wgsl",
  "category": "generative",
  "description": "A mesmerizing deep-space ocean with translucent aether-jellyfish reacting to audio.",
  "features": ["audio-reactive"],
  "params": [
    {
      "id": "param1",
      "name": "Swarm Density",
      "type": "slider",
      "min": 1,
      "max": 30,
      "default": 10,
      "step": 1,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Propulsion Speed",
      "type": "slider",
      "min": 0.1,
      "max": 5,
      "default": 1,
      "step": 0.1,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Bioluminescence Intensity",
      "type": "slider",
      "min": 0.5,
      "max": 10,
      "default": 2,
      "step": 0.1,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Tentacle Length",
      "type": "slider",
      "min": 1,
      "max": 15,
      "default": 5,
      "step": 0.5,
      "mapping": "zoom_params.w"
    }
  ]
}
