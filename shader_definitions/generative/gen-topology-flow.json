{
  "id": "gen-topology-flow",
  "name": "Topology Flow",
  "url": "shaders/gen-topology-flow.wgsl",
  "description": "Topological surface flow visualization inspired by Morse theory, showing gradient flows converging and diverging at critical points",
  "tags": [
    "generative",
    "topology",
    "flow",
    "mathematical",
    "procedural",
    "audio",
    "music"
  ],
  "features": [
    "animated",
    "audio-reactive",
    "audio-driven"
  ],
  "params": [
    {
      "id": "flowSpeed",
      "name": "Flow Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "complexity",
      "name": "Height Complexity",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "particleDensity",
      "name": "Particle Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "trailPersistence",
      "name": "Trail Persistence",
      "default": 0.8,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
