{
  "id": "gen-apollonian-gasket",
  "name": "Apollonian Gasket",
  "url": "shaders/gen-apollonian-gasket.wgsl",
  "category": "generative",
  "description": "Apollonian circle packing fractal rendered via iterative circle inversion. Descartes-based circle configuration with metallic coloring, rainbow chromatic aberration on inversions, and mouse-driven point inversion.",
  "tags": [
    "generative",
    "fractal",
    "apollonian",
    "circle-packing",
    "geometric",
    "audio-reactive",
    "metallic"
  ],
  "features": [
    "procedural",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "recursion",
      "name": "Recursion Depth",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "inversion",
      "name": "Inversion Intensity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "size",
      "name": "Circle Size",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "rainbow",
      "name": "Rainbow Aberration",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
