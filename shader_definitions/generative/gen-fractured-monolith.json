{
  "id": "gen-fractured-monolith",
  "name": "Fractured Monolith",
  "url": "shaders/gen-fractured-monolith.wgsl",
  "description": "A massive, ancient monolith floating above a dark liquid sea, fractured into segmented pieces that pulse with an inner, ethereal light.",
  "tags": [
    "monolith",
    "floating",
    "fractured",
    "glowing",
    "ambient",
    "generative",
    "scifi",
    "audio",
    "music",
    "reactive"
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "audio-driven"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Fracture Spread",
      "min": 0,
      "max": 1,
      "default": 0.3,
      "step": 0.05,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Levitation Speed",
      "min": 0,
      "max": 3,
      "default": 1,
      "step": 0.1,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Glow Intensity",
      "min": 0,
      "max": 2,
      "default": 1,
      "step": 0.1,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Rotation Speed",
      "min": 0,
      "max": 2,
      "default": 0.5,
      "step": 0.1,
      "mapping": "zoom_params.w"
    }
  ]
}
