    "procedural",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "turbulence",
      "name": "Turbulence",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
