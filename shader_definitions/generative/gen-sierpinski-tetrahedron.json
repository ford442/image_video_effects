{
  "id": "gen-sierpinski-tetrahedron",
  "name": "Sierpinski Tetrahedron",
  "url": "shaders/gen-sierpinski-tetrahedron.wgsl",
  "category": "generative",
  "description": "3D Sierpinski tetrahedron rendered as a 2D projection with multi-orbit trap coloring (vertex, edge, shell). Domain-warped FBM distorts the view, jewel-tone palette with metallic sheen, HDR specular highlights, and audio-reactive recursion depth.",
  "tags": [
    "fractal",
    "sierpinski",
    "tetrahedron",
    "3d",
    "geometric",
    "jewel",
    "metallic"
  ],
  "features": [
    "audio-reactive",
    "mouse-driven",
    "temporal",
    "depth-aware",
    "domain-warping",
    "multi-orbit-trap"
  ],
  "params": [
    {
      "id": "recursion",
      "name": "Recursion Depth",
      "default": 0.45,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "rotation",
      "name": "Rotation Speed",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "perspective",
      "name": "Perspective",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "chromatic",
      "name": "Chromatic Aberration",
      "default": 0.25,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
