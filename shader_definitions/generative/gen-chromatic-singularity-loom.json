{
  "id": "gen-chromatic-singularity-loom",
  "name": "Chromatic Singularity-Loom",
  "tags": [
    "singularity",
    "fractal",
    "weaving",
    "space",
    "audio-reactive",
    "distortion"
  ],
  "description": "A majestic, gravity-warped cosmic loom weaving fractal strings of pure light around a central singularity.",
  "features": [
    "raymarched",
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "temporal-accretion",
    "chromatic-lensing",
    "audio-thread-chaos",
    "bass-mass-pulse"
  ],
  "parameters": [
    {
      "id": "gravity_mass",
      "name": "Gravity Mass",
      "type": "slider",
      "min": 0.1,
      "max": 10,
      "step": 0.1,
      "default": 2
    },
    {
      "id": "thread_density",
      "name": "Thread Density",
      "type": "slider",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "id": "accretion_glow",
      "name": "Accretion Glow",
      "type": "slider",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 1
    },
    {
      "id": "chromatic_shift",
      "name": "Chromatic Shift",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "default": 0.5
    }
  ],
  "url": "shaders/gen-chromatic-singularity-loom.wgsl",
  "params": [
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x",
      "description": "Controls the overall strength of the generated effect."
    },
    {
      "id": "speed",
      "name": "Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y",
      "description": "Controls animation and temporal evolution speed."
    },
    {
      "id": "scale",
      "name": "Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "Controls spatial scale, frequency, or detail contrast."
    },
    {
      "id": "mouseInfluence",
      "name": "Mouse Influence",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "Controls mouse-driven or secondary variation influence."
    }
  ]
}
