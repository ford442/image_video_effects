{
  "id": "gen-islamic-star-rose",
  "name": "Islamic Geometric Star-Rose",
  "category": "generative",
  "url": "shaders/gen-islamic-star-rose.wgsl",
  "description": "Procedurally generated Islamic geometric patterns enriched by Wolfram Alpha regular pentagon data. Interior angle 108°, central angle 72°. Diagonal/edge ratio φ≈1.618 determines petal proportions. Features girih-style star and polygon tessellations with pentagram-aware geometry. Bass rotates the tessellation. Mouse morphs between star and rose forms. Temporal feedback and chromatic aberration complete the upgraded-rgba stack.",
  "features": [
    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven",
    "interactive",
    "procedural",
    "geometric"
  ],
  "tags": [
    "islamic",
    "geometric",
    "girih",
    "tessellation",
    "star",
    "pentagram",
    "generative",
    "ornamental",
    "metallic",
    "wolfram"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Pattern Complexity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Rotation",
      "default": 0.15,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Zoom",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
