{
  "id": "gen-chaos-game-ifs",
  "name": "Chaos Game IFS",
  "url": "shaders/gen-chaos-game-ifs.wgsl",
  "description": "Iterated function system chaos game generating fractal attractors. Audio drives iteration depth and attractor scale. Rotating attractor points.",
  "tags": [
    "generative",
    "ifs",
    "chaos-game",
    "fractal",
    "attractor",
    "audio",
    "music"
  ],
  "features": [
    "generative",
    "audio-reactive",
    "upgraded-rgba",
    "chromatic-attractors",
    "temporal-ghosting"
  ],
  "params": [
    {
      "id": "iterations",
      "name": "Iterations",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "IFS iteration depth",
      "mapping": "zoom_params.x"
    },
    {
      "id": "glowSize",
      "name": "Glow Size",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Attractor glow radius",
      "mapping": "zoom_params.y"
    },
    {
      "id": "ringCount",
      "name": "Ring Count",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Density of concentric rings",
      "mapping": "zoom_params.z"
    },
    {
      "id": "saturation",
      "name": "Saturation",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Color saturation",
      "mapping": "zoom_params.w"
    }
  ]
}
