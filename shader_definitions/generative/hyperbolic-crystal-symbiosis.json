{
  "id": "hyperbolic-crystal-symbiosis",
  "name": "Hyperbolic Crystal Symbiosis",
  "url": "shaders/hyperbolic-crystal-symbiosis.wgsl",
  "category": "generative",
  "description": "Two crystal species grow and compete within a hyperbolic space. Bass increases aggression between species while mids encourage beautiful symbiotic blending. Mouse position warps local curvature.",
  "features": [
    "hyperbolic-geometry",
    "competing-growth",
    "audio-competition",
    "mouse-curvature",
    "crystalline"
  ],
  "tags": [
    "hyperbolic",
    "crystalline",
    "symbiosis",
    "geometric",
    "audio-reactive",
    "abstract"
  ],
  "params": [
    {
      "id": "curvature",
      "name": "Base Curvature",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x",
      "description": "Strength of the hyperbolic distortion"
    },
    {
      "id": "competition",
      "name": "Species Tension",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y",
      "description": "How strongly the two crystal types compete"
    },
    {
      "id": "symbiosis",
      "name": "Symbiotic Tendency",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "Encourages beautiful blending between species"
    },
    {
      "id": "mousePower",
      "name": "Mouse Curvature Power",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "How strongly the mouse warps local geometry"
    }
  ]
}