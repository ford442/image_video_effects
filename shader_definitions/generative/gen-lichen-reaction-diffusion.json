{
  "id": "gen-lichen-reaction-diffusion",
  "name": "Lichen Reaction-Diffusion",
  "category": "generative",
  "url": "shaders/gen-lichen-reaction-diffusion.wgsl",
  "description": "Gray-Scott reaction-diffusion system simulating lichen growth patterns. Creates organic, slowly evolving patterns including coral lichens, leopard spots, and maze-like structures. Patterns morph across different RD regimes. Mouse deposits additional activator chemical.",
  "features": [
    "interactive",
    "mouse-reactive",
    "temporal",
    "procedural",
    "organic",
    "simulation"
  ],
  "tags": [
    "reaction-diffusion",
    "lichen",
    "organic",
    "patterns",
    "grayscott",
    "generative",
    "nature",
    "growth"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Pattern Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Growth Rate",
      "default": 0.2,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Zoom",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorshift",
      "name": "Color Shift",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
