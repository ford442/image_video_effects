{
  "id": "gen-quantum-chrome-serpent-ouroboros",
  "name": "Quantum-Chrome Serpent Ouroboros",
  "url": "shaders/gen-quantum-chrome-serpent-ouroboros.wgsl",
  "category": "generative",
  "description": "A hyper-dimensional, endlessly twisting serpentine ring forged of liquid-chrome and fractal dark matter that consumes its own geometric tail while weaving a tapestry of light across the void.",
  "features": [
    "metallic",
    "serpent",
    "fractal",
    "audio-reactive",
    "liquid-chrome"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Coil Tightness",
      "type": "slider",
      "min": 0.5,
      "max": 3.0,
      "default": 1.5,
      "step": 0.1,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Scale Density",
      "type": "slider",
      "min": 0.1,
      "max": 2.5,
      "default": 1.0,
      "step": 0.1,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Core Heat",
      "type": "slider",
      "min": 1.0,
      "max": 5.0,
      "default": 2.0,
      "step": 0.1,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Dispersion",
      "type": "slider",
      "min": 0.5,
      "max": 2.5,
      "default": 1.2,
      "step": 0.1,
      "mapping": "zoom_params.w"
    }
  ]
}