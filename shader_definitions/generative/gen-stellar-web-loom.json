{
  "id": "gen-stellar-web-loom",
  "name": "Stellar Web-Loom",
  "url": "shaders/gen-stellar-web-loom.wgsl",
  "description": "A hyper-dimensional cosmic loom weaving infinite tendrils of starlight and plasma silk across a dark void, blending organic neuro-network vibes with vast, mechanical astrophysics.",
  "tags": [
    "cosmic",
    "neuro",
    "plasma",
    "volumetric",
    "audio-reactive",
    "audio",
    "music",
    "reactive"
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "audio-driven"
  ],
  "params": [
    {
      "id": "threadDensity",
      "name": "Thread Density",
      "default": 2,
      "min": 0.5,
      "max": 5,
      "step": 0.1,
      "mapping": "zoom_params.x"
    },
    {
      "id": "weaveSpeed",
      "name": "Weave Speed",
      "default": 1,
      "min": 0,
      "max": 3,
      "step": 0.1,
      "mapping": "zoom_params.y"
    },
    {
      "id": "plasmaGlow",
      "name": "Plasma Glow",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 0.1,
      "mapping": "zoom_params.z"
    },
    {
      "id": "threadOpacityExp",
      "name": "Thread Opacity Exponent",
      "default": 1,
      "min": 0.25,
      "max": 3,
      "step": 0.05,
      "mapping": "zoom_params.w"
    }
  ]
}
