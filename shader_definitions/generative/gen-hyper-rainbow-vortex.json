    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "vortex",
    "rainbow",
    "spiral",
    "chromatic",
    "fluid-dynamics",
    "rankine"
  ],
