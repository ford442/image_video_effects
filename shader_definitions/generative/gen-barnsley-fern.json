{
  "id": "gen-barnsley-fern",
  "name": "Barnsley Fern",
  "url": "shaders/gen-barnsley-fern.wgsl",
  "category": "generative",
  "description": "A self-similar fractal fern generated by an iterated function system with 4 affine transformations. Natural forest palette with HDR sunlight filtering through fronds. Audio morphs between fern varieties, mouse attracts frond tips, and depth controls leaf detail.",
  "features": [
    "procedural",
    "fractal",
    "barnsley-ifs",
    "audio-reactive",
    "mouse-driven",
    "aces-tonemap",
    "chromatic-aberration",
    "temporal-feedback",
    "depth-aware",
    "upgraded-rgba"
  ],
  "tags": [
    "fractal",
    "fern",
    "nature",
    "green",
    "organic",
    "ifs",
    "mathematical",
    "abstract"
  ],
  "params": [
    {
      "id": "scale",
      "name": "Fern Scale",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.x",
      "description": "Overall size of the fern"
    },
    {
      "id": "chromatic",
      "name": "Chromatic Aberration",
      "default": 0.3,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.y",
      "description": "Color fringe on fern edges"
    },
    {
      "id": "brightness",
      "name": "Sunlight Brightness",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "HDR sunlight intensity through fronds"
    },
    {
      "id": "feedback",
      "name": "Temporal Feedback",
      "default": 0.2,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "Ghosting from previous frames"
    }
  ]
}
