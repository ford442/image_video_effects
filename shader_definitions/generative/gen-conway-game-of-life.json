{
  "id": "gen-conway-game-of-life",
  "name": "Conway Game of Life",
  "category": "generative",
  "url": "shaders/gen-conway-game-of-life.wgsl",
  "description": "Conway's Game of Life cellular automaton rendered with glowing neon cell states on a coarse grid. Rules morph between Classic, Day & Night, and HighLife over time. Bass triggers random cell births, mouse draws live cells, and depth controls grid density. Features temporal persistence for death fade trails and chromatic aberration on state-change events.",
  "features": [
    "audio-reactive",
    "mouse-interactive",
    "depth-aware",
    "temporal-feedback",
    "procedural",
    "cellular-automata"
  ],
  "tags": [
    "conway",
    "game-of-life",
    "cellular-automata",
    "neon",
    "emergence",
    "generative",
    "gliders",
    "spaceships"
  ],
  "params": [
    {
      "id": "seedDensity",
      "name": "Seed Density",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Rule Morph Speed",
      "default": 0.2,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "gridScale",
      "name": "Grid Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "trailDecay",
      "name": "Trail Decay",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
