{
  "id": "phosphorescent-jellyfish",
  "name": "Phosphorescent Jellyfish",
  "url": "shaders/phosphorescent-jellyfish.wgsl",
  "description": "Glowing jellyfish with trailing tentacle bioluminescence. Bass pulses the bell contraction, mids create tentacle wave motion, treble adds individual photophore sparkles. Mouse attracts the jellyfish swarm.",
  "tags": [
    "generative",
    "bioluminescent",
    "organic",
    "audio-reactive",
    "mouse-driven",
    "temporal",
    "chromatic",
    "underwater"
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "temporal"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Swarm Count",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Bell Size",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Trail Persistence",
      "default": 0.9,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Glow Intensity",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
