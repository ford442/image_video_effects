    "animated",
    "audio-reactive",
    "audio-driven"
  ],
  "params": [
    {
      "id": "growthSpeed",
      "name": "Growth Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
