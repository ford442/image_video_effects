{
  "id": "gen-mandelbox-explorer",
  "name": "Mandelbox Explorer",
  "url": "shaders/gen-mandelbox-explorer.wgsl",
  "category": "generative",
  "description": "2D cross-section of the 3D Mandelbox fractal with box folding, sphere folding, and orbit-trap coloring. Metallic surface with ambient occlusion, HDR specular highlights, and ACES tone mapping.",
  "tags": [
    "generative",
    "fractal",
    "mandelbox",
    "orbit-trap",
    "audio-reactive",
    "metallic",
    "futuristic"
  ],
  "features": [
    "procedural",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "scale",
      "name": "Box Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "iterations",
      "name": "Iterations",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "slice",
      "name": "Slice Thickness",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "specular",
      "name": "Specular",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
