      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "How much new resources appear"
    },
    {
      "id": "mouseNurture",
      "name": "Mouse Nurturing Power",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
