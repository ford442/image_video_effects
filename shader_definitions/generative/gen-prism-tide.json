{
  "id": "gen-prism-tide",
  "name": "Prism Tide",
  "url": "shaders/gen-prism-tide.wgsl",
  "category": "generative",
  "description": "Refractive chroma tides form spectral wavefronts and foam-like interference crests.",
  "tags": [
    "generative",
    "prismatic",
    "interference",
    "waves",
    "audio-reactive",
    "colorful"
  ],
  "features": [
    "procedural",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba",
    "temporal",
    "chromatic",
    "depth-aware"
  ],
  "params": [
    {
      "id": "waveScale",
      "name": "Wave Scale",
      "default": 0.44,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "refraction",
      "name": "Refraction",
      "default": 0.38,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "pulse",
      "name": "Pulse",
      "default": 0.47,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "saturation",
      "name": "Saturation",
      "default": 0.58,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
