{
  "id": "gen-liquid-rainbow-glass",
  "name": "Liquid Rainbow Glass",
  "category": "generative",
  "url": "shaders/gen-liquid-rainbow-glass.wgsl",
  "description": "Simulates looking through liquid rainbow glass - thick translucent layers of flowing color with refraction-like effects. Colors blend and swirl like oil in water but extremely bright and saturated. Chromatic dispersion at edges. Mouse stirs the liquid creating swirling vortices.",
  "features": [
    "interactive",
    "mouse-reactive",
    "temporal",
    "procedural",
    "upgraded-rgba"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "liquid",
    "glass",
    "refraction",
    "chromatic",
    "oil",
    "swirl"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.65,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Speed",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Scale",
      "default": 0.45,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorshift",
      "name": "Color Shift",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
