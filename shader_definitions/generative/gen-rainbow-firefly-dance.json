{
  "id": "gen-rainbow-firefly-dance",
  "name": "Rainbow Firefly Dance",
  "category": "generative",
  "url": "shaders/gen-rainbow-firefly-dance.wgsl",
  "description": "Hundreds of glowing firefly-like particles dancing in organic swirling patterns. Each firefly has a unique rainbow color that cycles over time. Bright neon glow halos around each particle. Mouse attracts the swarm. Fireflies leave brief phosphorescent trails.",
  "features": [
    "interactive",
    "mouse-reactive",
    "temporal",
    "procedural"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "particles",
    "glow",
    "fireflies",
    "rainbow",
    "organic"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Speed",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorshift",
      "name": "Color Shift",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
