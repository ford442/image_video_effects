{
  "id": "gen-feedback-echo-chamber",
  "name": "Feedback Echo Chamber",
  "url": "shaders/gen-feedback-echo-chamber.wgsl",
  "description": "Multi-layer temporal echo with feedback decay, creating ghost images of previous frames fading into depth with color grading per layer",
  "tags": [
    "temporal",
    "echo",
    "feedback",
    "multi-layer",
    "ghosting",
    "audio",
    "music",
    "reactive",
    "alpha",
    "accumulative"
  ],
  "features": [
    "aces-tone-map",
    "advanced-alpha",
    "audio-driven",
    "audio-reactive",
    "chromatic-aberration",
    "depth-aware",
    "multi-pass",
    "temporal",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "echoCount",
      "name": "Echo Count",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "decayRate",
      "name": "Decay Rate",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "spacing",
      "name": "Echo Spacing",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorShift",
      "name": "Color Shift",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
