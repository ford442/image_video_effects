    "mouse-reactive",
    "shockwave"
  ],
  "features": [
    "aces-tone-map",
    "advanced-alpha",
    "audio-driven",
    "audio-reactive",
    "chromatic-aberration",
    "depth-aware",
    "domain-warp",
    "gravity-well",
    "mouse-reactive",
    "multi-pass",
    "psychedelic-palette",
    "shockwave",
    "temporal",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "echoCount",
      "name": "Echo Count",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "decayRate",
      "name": "Decay Rate",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "spacing",
      "name": "Echo Spacing",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorShift",
      "name": "Color Shift",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
