    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven",
    "procedural"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "geometry",
    "acid",
    "morphing",
    "additive",
    "shapes",
    "ph-science",
    "chemistry"
  ],
