{
  "id": "gen-neon-snowfall",
  "name": "Neon Snowfall",
  "url": "shaders/gen-neon-snowfall.wgsl",
  "category": "generative",
  "description": "Chromatic snow particles descend in luminous streaks with high-frequency treble twinkle.",
  "tags": [
    "generative",
    "snow",
    "neon",
    "particles",
    "winter",
    "audio-reactive"
  ],
  "features": [
    "procedural",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba",
    "temporal",
    "chromatic",
    "depth-aware"
  ],
