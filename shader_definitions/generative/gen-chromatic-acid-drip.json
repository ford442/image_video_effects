{
  "id": "gen-chromatic-acid-drip",
  "name": "Chromatic Acid Drip",
  "category": "generative",
  "url": "shaders/gen-chromatic-acid-drip.wgsl",
  "description": "Liquid LSD-like chromatic dripping with RGB channel separation. Upgraded with universal-indicator pH color science: drips change color as they fall through a realistic acid→base gradient. Mouse creates localized acid/base splashes. Critical-angle refraction, temporal feedback trails, chromatic aberration, and ACES tone mapping.",
  "features": [
    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven",
    "procedural"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "acid",
    "liquid",
    "chromatic",
    "drip",
    "ferrofluid",
    "metaball",
    "ph-science",
    "chemistry"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.65,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Flow Speed",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Blob Scale",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
