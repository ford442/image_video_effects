{
  "id": "gen-translucent-nebula",
  "name": "Translucent Nebula",
  "url": "shaders/gen-translucent-nebula.wgsl",
  "description": "Volumetric gas clouds with density-based alpha translucency. FBM and Worley noise create organic nebula structure where dense cores are opaque and edges fade to transparent. Star sparkle reacts to treble and nebula pulses with bass.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "temporal",
    "upgraded-rgba"
  ],
  "tags": [
    "nebula",
    "volumetric",
    "gas",
    "stars",
    "translucent",
    "worley-noise"
  ],
  "params": [
    {
      "id": "density",
      "name": "Cloud Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "scale",
      "name": "Cloud Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "color_shift",
      "name": "Color Shift",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "stars",
      "name": "Star Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
