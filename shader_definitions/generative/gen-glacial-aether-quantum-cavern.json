{
  "id": "gen-glacial-aether-quantum-cavern",
  "name": "Glacial-Aether Quantum-Cavern",
  "tags": [
    "fractal",
    "ice",
    "quantum",
    "reactive",
    "volumetric",
    "cavern"
  ],
  "description": "An infinitely deep, freezing subterranean cavern of quantum ice that glows with auroral aether-plasma, physically cracking and echoing with kaleidoscopic light refractions upon heavy bass impulses.",
  "params": [
    {
      "id": "param1",
      "name": "Ice Density",
      "type": "slider",
      "default": 0.5,
      "min": 0.1,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Plasma Glow",
      "type": "slider",
      "default": 0.8,
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Fracture Rate",
      "type": "slider",
      "default": 0.2,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Cavern Scale",
      "type": "slider",
      "default": 1.5,
      "min": 0.5,
      "max": 3,
      "step": 0.05,
      "mapping": "zoom_params.w"
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "chromatic-depth",
    "temporal-ice-formation",
    "audio-fracture"
  ],
  "url": "shaders/gen-glacial-aether-quantum-cavern.wgsl"
}
