{
  "id": "gen-grokcf-voronoi",
  "name": "Worley Cellular",
  "url": "shaders/gen_grokcf_voronoi.wgsl",
  "description": "Audio-reactive Worley cellular fields with thin-film interference edge glow and micro-cosmic starfields hidden inside each cell.",
  "features": [
    "mouse-driven",
    "depth-aware",
    "upgraded-rgba",
    "animated",
    "audio-reactive",
    "procedural",
    "organic-cellular"
  ],
  "tags": [
    "procedural",
    "generative",
    "voronoi",
    "cellular",
    "worley",
    "audio-reactive",
    "thin-film",
    "vj"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Cell Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Edge Glow",
      "default": 0.55,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Color Shift",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Parallax",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
