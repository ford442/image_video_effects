      "max": 1,
      "step": 0.01,
      "description": "Hue rotation of the color palette",
      "mapping": "zoom_params.z"
    },
    {
      "id": "detailLevel",
      "name": "Detail Level",
      "default": 0.4,
      "min": 0,
