      "min": 0.0,
      "max": 1.0,
      "step": 0.01
    },
    {
      "id": "speed",
      "name": "Evolution Speed",
      "default": 0.2,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01
    },
    {
