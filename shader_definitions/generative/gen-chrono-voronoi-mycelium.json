{
  "id": "gen-chrono-voronoi-mycelium",
  "name": "Chrono-Voronoi Mycelium",
  "url": "shaders/gen-chrono-voronoi-mycelium.wgsl",
  "description": "Multi-temporal Voronoi fungal growth system where different generations of mycelium exist as layered temporal states, creating organic networks that evolve across time. Mouse introduces nutrients affecting multiple time layers. Audio controls growth vs decay rates.",
  "tags": [
    "generative",
    "voronoi",
    "organic",
    "mycelium",
    "temporal",
    "procedural",
    "audio",
    "music",
    "reactive"
  ],
  "features": [
    "generative",
    "audio-reactive",
    "mouse-driven"
  ],
  "params": [
    {
      "id": "growthRate",
      "name": "Growth Rate",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Speed of mycelial growth across time layers",
      "mapping": "zoom_params.x"
    },
    {
      "id": "generations",
      "name": "Generations",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Number of temporal mycelium generations",
      "mapping": "zoom_params.y"
    },
    {
      "id": "decay",
      "name": "Decay Rate",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "How quickly older generations fade",
      "mapping": "zoom_params.z"
    },
    {
      "id": "glow",
      "name": "Tip Glow",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Intensity of glowing network tips",
      "mapping": "zoom_params.w"
    }
  ]
}
