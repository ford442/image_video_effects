    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "rainbow",
    "polar",
    "explosion",
    "rays",
    "particles",
    "shock-wave",
    "fluid-dynamics"
  ],
