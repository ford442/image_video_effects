      "type": "slider",
      "min": 0,
      "max": 3,
      "default": 1.5,
      "step": 0.1,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Pollen Density",
      "type": "slider",
      "min": 0,
      "max": 10,
      "default": 5,
      "step": 0.5,
      "mapping": "zoom_params.w"
    }
