{
  "id": "gen-rainbow-smoke",
  "name": "Rainbow Smoke with Dual Scattering",
  "url": "shaders/gen_rainbow_smoke.wgsl",
  "description": "Multi-scale rainbow smoke with vorticity confinement, buoyancy, Rayleigh edge glow, and Mie-lit cores driven by bass and treble.",
  "features": [
    "upgraded-rgba",
    "depth-aware",
    "audio-reactive",
    "mouse-driven",
    "temporal"
  ],
  "tags": [
    "procedural",
    "generative",
    "smoke",
    "audio-reactive",
    "scattering",
    "volumetric"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Emission",
      "default": 0.55,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Turbulence",
      "default": 0.65,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Scattering",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Advection",
      "default": 0.55,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
