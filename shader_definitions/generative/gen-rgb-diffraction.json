{
  "id": "gen-rgb-diffraction",
  "name": "RGB Diffraction",
  "url": "shaders/gen-rgb-diffraction.wgsl",
  "description": "Simulates a multi-slit diffraction grating where separate red, green, and blue wavelengths produce offset interference fringe patterns. Six-fold rotational symmetry creates a spectral starburst. Slit orientation and frequency pulse to audio for reactive prism effects.",
  "features": [
    "audio-reactive",
    "audio-driven",
    "procedural",
    "temporal",
    "chromatic",
    "depth-aware"
  ],
  "tags": [
    "psychedelic",
    "colorful",
    "diffraction",
    "prismatic",
    "spectral",
    "interference",
    "rainbow",
    "generative",
    "abstract"
  ],
  "params": [
    {
      "id": "speed",
      "name": "Evolution Speed",
      "default": 0.35,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "freq",
      "name": "Fringe Frequency",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "chromab",
      "name": "Chromatic Spread",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "brightness",
      "name": "Brightness",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
