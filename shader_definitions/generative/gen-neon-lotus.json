{
  "id": "gen-neon-lotus",
  "name": "Neon Lotus",
  "url": "shaders/gen-neon-lotus.wgsl",
  "category": "generative",
  "description": "A blooming neon lotus flower with layered petals unfolding in real-time. Bass swells the bloom, mids shift the chromatic glow, treble adds iridescent shimmer on each petal edge.",
  "tags": [
    "lotus",
    "flower",
    "neon",
    "generative",
    "audio-reactive",
    "colorful",
    "abstract",
    "psychedelic"
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "petalCount",
      "name": "Petal Count",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "bloom",
      "name": "Bloom",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "speed",
      "name": "Speed",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "glowScale",
      "name": "Glow Scale",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
