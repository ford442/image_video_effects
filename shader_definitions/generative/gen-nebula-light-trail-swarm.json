{
  "id": "gen-nebula-light-trail-swarm",
  "name": "Nebula Light-Trail Swarm",
  "url": "shaders/gen-nebula-light-trail-swarm.wgsl",
  "description": "Photon-like particles race through the scene leaving glowing, fading trails that pulse with audio. Creates a constantly reforming nebula.",
  "features": [
    "audio-reactive",
    "mouse-driven",
    "generative",
    "temporal",
    "chromatic",
    "depth-aware"
  ],
  "tags": [
    "nebula",
    "particles",
    "trails",
    "glow",
    "audio",
    "generative",
    "space"
  ],
  "params": [
    {
      "id": "speed",
      "name": "Particle Speed",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "trailDecay",
      "name": "Trail Decay",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "curlStrength",
      "name": "Curl Strength",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "glowRadius",
      "name": "Glow Radius",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
