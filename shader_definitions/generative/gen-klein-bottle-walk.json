{
  "id": "gen-klein-bottle-walk",
  "name": "Klein Bottle Walk",
  "url": "shaders/gen-klein-bottle-walk.wgsl",
  "description": "Parametric walk across a Klein bottle surface with FBM texture, diffuse/specular lighting, and audio-reactive color modulation.",
  "tags": [
    "generative",
    "klein-bottle",
    "parametric",
    "3d",
    "surface",
    "audio",
    "music"
  ],
  "features": [
    "generative",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "walkSpeed",
      "name": "Walk Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Speed of surface traversal",
      "mapping": "zoom_params.x"
    },
    {
      "id": "textureDensity",
      "name": "Texture Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "FBM surface texture detail",
      "mapping": "zoom_params.y"
    },
    {
      "id": "lightIntensity",
      "name": "Light Intensity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Specular highlight strength",
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorShift",
      "name": "Color Shift",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Base color offset",
      "mapping": "zoom_params.w"
    }
  ]
}
