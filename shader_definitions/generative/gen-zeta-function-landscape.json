{
  "id": "gen-zeta-function-landscape",
  "name": "Zeta Function Landscape",
  "url": "shaders/gen-zeta-function-landscape.wgsl",
  "description": "Riemann zeta function visualization on the critical line. Magnitude creates landscape height, zeros form valleys. Audio reactivity modulates term count and color cycling.",
  "tags": [
    "generative",
    "mathematical",
    "zeta",
    "riemann",
    "landscape",
    "abstract",
    "audio",
    "music"
  ],
  "features": [
    "generative",
    "audio-reactive",
    "mouse-driven",
    "upgraded-rgba",
    "chromatic-zeros",
    "temporal-smoothing"
  ],
  "params": [
    {
      "id": "sigma",
      "name": "Sigma Offset",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Deviation from critical line (0.5)",
      "mapping": "zoom_params.x"
    },
    {
      "id": "range",
      "name": "T Range",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Width of t-axis exploration",
      "mapping": "zoom_params.y"
    },
    {
      "id": "heightScale",
      "name": "Height Scale",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Vertical exaggeration of landscape",
      "mapping": "zoom_params.z"
    },
    {
      "id": "terms",
      "name": "Term Precision",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Zeta series term count",
      "mapping": "zoom_params.w"
    }
  ]
}
