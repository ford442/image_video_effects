{
  "id": "gen-neon-neural-network",
  "name": "Neon Neural Network",
  "category": "generative",
  "url": "shaders/gen-neon-neural-network.wgsl",
  "description": "A glowing neon neural network visualization enriched with ReLU activation mathematics. Neurons fire using R(x)=max(0,x) thresholds. Bass drives input layer activation intensity. Mids control synaptic connection strength. Treble adds backpropagation error glow as red halos along edges. Network layers visualized as concentric rings of neurons with pulsing signal paths. Mouse controls a cursor node that lights up nearby connections.",
  "features": [
    "upgraded-rgba",
    "temporal",
    "audio-reactive",
    "mouse-driven",
    "neural-relu",
    "procedural"
  ],
  "tags": [
    "psychedelic",
    "neon",
    "network",
    "glow",
    "signals",
    "data-flow",
    "generative",
    "neural",
    "relu",
    "ai",
    "abstract"
  ],
  "params": [
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.7,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "speed",
      "name": "Signal Speed",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "scale",
      "name": "Network Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "colorshift",
      "name": "Color Shift",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
