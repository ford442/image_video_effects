      "id": "growth",
      "name": "Growth Speed",
      "default": 0.65,
      "min": 0.0,
      "max": 1.4,
      "step": 0.01,
      "param": "zoom_params.x"
    },
    {
      "id": "polypSize",
      "name": "Polyp Size",
      "default": 0.55,
      "min": 0.2,
      "max": 1.0,
      "step": 0.01,
      "param": "zoom_params.y"
    },
    {
      "id": "colorVariety",
      "name": "Color Variety",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "param": "zoom_params.z"
    },
    {
      "id": "mouseAttraction",
      "name": "Mouse Attraction",
      "default": 0.6,
      "min": 0.0,
      "max": 1.3,
      "step": 0.01,
      "param": "zoom_params.w"
    }
  ]
}