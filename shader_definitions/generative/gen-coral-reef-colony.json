{
  "id": "gen-coral-reef-colony",
  "name": "Coral Reef Colony",
  "url": "shaders/gen-coral-reef-colony.wgsl",
  "category": "generative",
  "description": "Organic, growing coral structures that respond to audio and are attracted to the mouse. Feels alive and underwater.",
