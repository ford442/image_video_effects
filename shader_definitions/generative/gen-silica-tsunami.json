    {
      "id": "waveHeight",
      "name": "Wave Height",
      "min": 0.0,
      "max": 5.0,
      "default": 2.0,
      "step": 0.1
    },
    {
      "id": "glassRefraction",
      "name": "Glass Refraction",
      "min": 0.0,
      "max": 1.0,
      "default": 0.8,
      "step": 0.05
    },
    {
      "id": "particleDensity",
      "name": "Particle Density",
      "min": 0.1,
      "max": 2.0,
      "default": 1.0,
      "step": 0.1
    },
    {
      "id": "audioReactivity",
      "name": "Audio Reactivity",
      "min": 0.0,
      "max": 3.0,
      "default": 1.5,
      "step": 0.1
    }
  ]
}
