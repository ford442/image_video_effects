{
  "id": "gen-quantum-foam",
  "name": "Quantum Foam",
  "url": "shaders/gen-quantum-foam.wgsl",
  "category": "generative",
  "description": "Spacetime seething at the Planck scale: Worley-noise bubbles pop in chromatic iridescence. Bass amplifies density, treble brightens cell borders, creating a living quantum vacuum.",
  "tags": [
    "quantum",
    "foam",
    "cellular",
    "abstract",
    "audio-reactive",
    "generative",
    "cosmic",
    "procedural"
  ],
  "features": [
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "density",
      "name": "Density",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "bubbleSize",
      "name": "Bubble Size",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "chroma",
      "name": "Chroma",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "speed",
      "name": "Speed",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
