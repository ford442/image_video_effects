{
  "id": "gen-percolation-threshold",
  "name": "Percolation Threshold",
  "url": "shaders/gen-percolation-threshold.wgsl",
  "description": "Site percolation on a 2D square lattice near the critical threshold p_c ≈ 0.5927. Iterative connected-component labeling with jewel-tone cluster coloring and HDR spanning-cluster bloom.",
  "features": [
    "generative",
    "audio-reactive",
    "mouse-driven",
    "temporal",
    "depth-aware"
  ],
  "tags": [
    "procedural",
    "generative",
    "percolation",
    "phase-transition",
    "clusters",
    "lattice",
    "audio-reactive",
    "cellular-automaton"
  ],
  "params": [
    {
      "id": "param1",
      "name": "Threshold Shift",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "param2",
      "name": "Lattice Zoom",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "param3",
      "name": "Bloom",
      "default": 0.6,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "param4",
      "name": "Grain",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ]
}
