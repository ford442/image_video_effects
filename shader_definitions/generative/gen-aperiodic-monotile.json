{
  "id": "gen-aperiodic-monotile",
  "name": "Aperiodic Monotile Hat",
  "url": "shaders/gen-aperiodic-monotile.wgsl",
  "description": "Aperiodic hat tiling (monotile) with animated edge glow and audio-reactive color cycling. Rotates and scales with parameters.",
  "tags": [
    "generative",
    "tiling",
    "aperiodic",
    "monotile",
    "hat",
    "geometric",
    "audio",
    "music"
  ],
  "features": [
    "generative",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "scale",
      "name": "Tile Scale",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Density of tiling"
    },
    {
      "id": "rotation",
      "name": "Rotation Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Speed of tiling rotation"
    },
    {
      "id": "edgeWidth",
      "name": "Edge Width",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Width of tile edge glow"
    },
    {
      "id": "saturation",
      "name": "Saturation",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "description": "Color saturation intensity"
    }
  ]
}
