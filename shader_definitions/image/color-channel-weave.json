    {
      "id": "thread_spacing",
      "name": "Thread Spacing",
      "default": 0.25,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "weave_angle",
      "name": "Weave Angle",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "shadow_depth",
      "name": "Shadow Depth",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "chroma_offset",
      "name": "Chroma Offset",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ]
}
