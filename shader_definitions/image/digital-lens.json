{
  "id": "digital-lens",
  "name": "Digital Lens",
  "url": "shaders/digital-lens.wgsl",
  "category": "image",
  "description": "A lens that pixelates the image and adds a digital grid under the cursor. Upgraded with early-exit optimization, named constants, helper functions, and HDR-ready output.",
  "params": [
    {
      "id": "block",
      "name": "Pixel Size",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "radius",
      "name": "Lens Radius",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "grid",
      "name": "Grid Opacity",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "tint",
      "name": "Matrix Tint",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    }
  ],
  "features": [
    "mouse-driven",
    "expects-pp-tone-map"
  ],
  "tags": [
    "filter",
    "image-processing",
    "pixelate",
    "lens",
    "digital"
  ]
}
