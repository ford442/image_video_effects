{
  "id": "chrono-slit-scan",
  "name": "Chrono Slit Scan",
  "url": "shaders/chrono-slit-scan.wgsl",
  "category": "image",
  "description": "Accumulates time slices of the video into a static image via FBM-warped SDF slits with spatially-varying temporal decay.",
  "params": [
    {
      "id": "speed",
      "name": "Scan Speed",
      "default": 0.3,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "width",
      "name": "Slit Width",
      "default": 0.2,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "warp",
      "name": "Time Warp",
      "default": 0.1,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "freeze",
      "name": "Fade Reset",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0
    }
  ],
  "features": [
    "temporal-persistence",
    "audio-reactive",
    "fbm-warp",
    "sdf-composition"
  ],
  "tags": [
    "filter",
    "image-processing",
    "noise",
    "fractal",
    "temporal"
  ]
}
