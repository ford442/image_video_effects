{
  "id": "voxel-depth-sort",
  "name": "Voxel Depth Sort",
  "category": "image",
  "url": "shaders/voxel-depth-sort.wgsl",
  "description": "Converts the image into a 3D grid of isometric floating blocks. Block height is determined by brightness and depth, with ambient occlusion, soft shadows, and mouse-rotated isometric projection.",
  "params": [
    {
      "id": "gridSize",
      "name": "Block Size",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "extrusion",
      "name": "Extrusion",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "shadow",
      "name": "BG Darken",
      "default": 0.8,
      "min": 0,
      "max": 1
    },
    {
      "id": "gap",
      "name": "Block Gap",
      "default": 0.2,
      "min": 0,
      "max": 0.8
    }
  ],
  "features": [
    "mouse-driven",
    "3d-effect",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba"
  ],
  "tags": [
    "voxel",
    "depth",
    "3d",
    "audio-reactive",
    "isometric",
    "ambient-occlusion"
  ]
}
