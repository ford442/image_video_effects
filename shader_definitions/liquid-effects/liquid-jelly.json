      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "Wave distortion amount"
    },
    {
      "id": "color_shift",
      "name": "Color Shift",
      "default": 0.3,
      "min": 0.0,
      "max": 1.0,
