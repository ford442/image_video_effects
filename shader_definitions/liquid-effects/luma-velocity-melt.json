{
  "id": "luma-velocity-melt",
  "name": "Luma Velocity Melt",
  "category": "liquid-effects",
  "url": "shaders/luma-velocity-melt.wgsl",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba",
    "chromatic-drip",
    "curl-turbulence"
  ],
  "description": "Image melts downwards with curl-noise turbulence. Bright pixels drip faster; chromatic separation makes R/B channels drip at different rates. Audio heat pulses and depth viscosity modulate flow.",
  "params": [
    {
      "name": "Melt Speed",
      "id": "melt-speed",
      "default": 0.005,
      "min": 0,
      "max": 0.02
    },
    {
      "name": "Heat Intensity",
      "id": "heat-intensity",
      "default": 2,
      "min": 0,
      "max": 5
    },
    {
      "name": "Persistence",
      "id": "persistence",
      "default": 0.95,
      "min": 0.5,
      "max": 0.999
    },
    {
      "name": "Luma Threshold",
      "id": "luma-threshold",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "liquid",
    "melt",
    "audio-reactive",
    "depth-aware",
    "chromatic",
    "curl-noise"
  ]
}
