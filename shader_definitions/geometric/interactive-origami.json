    "mouse-driven",
    "depth-aware",
    "audio-reactive",
    "temporal"
  ],
  "params": [
    {
      "id": "fold_scale",
      "name": "Fold Scale",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "fold_depth",
      "name": "Fold Depth",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "light_intensity",
      "name": "Light Intensity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "depth_influence",
      "name": "Depth Influence",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ],
  "tags": [
