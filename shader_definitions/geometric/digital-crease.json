    {
      "id": "foldCount",
      "name": "Fold Count",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "foldDepth",
      "name": "Fold Depth",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "foldSoftness",
      "name": "Fold Softness",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "chromaOffset",
      "name": "Chromatic Offset",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba",
    "temporal-paper-fold",
    "chromatic-folding"
  ],
  "tags": [
