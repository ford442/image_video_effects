{
  "id": "adaptive-mosaic",
  "name": "Adaptive Mosaic",
  "url": "shaders/adaptive-mosaic.wgsl",
  "description": "Depth-adaptive tile mosaic: near objects render as fine tiles, far objects as coarse blocks. SDF bevel on every tile edge, Voronoi crackle overlay at coarse sizes, mouse-focus zone, and audio-reactive tile-size pulse.",
  "features": [
    "mouse-driven",
    "depth-aware",
    "audio-reactive",
    "temporal"
  ],
  "params": [
    {
      "id": "tile_size",
      "name": "Tile Size",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "depth_blend",
      "name": "Depth Blend",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "bevel_width",
      "name": "Bevel Width",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "audio_sensitivity",
      "name": "Audio Sensitivity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ],
  "tags": [
    "mosaic",
    "pixel",
    "geometric",
    "depth",
    "voronoi",
    "tiles",
    "pattern",
    "audio",
    "reactive"
  ]
}
