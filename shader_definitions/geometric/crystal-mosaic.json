{
  "id": "crystal-mosaic",
  "name": "Crystal Mosaic",
  "category": "geometric",
  "url": "shaders/crystal-mosaic.wgsl",
  "description": "Image broken into triangular mosaic tiles that rotate based on mouse proximity. Chromatic edges at tile boundaries with depth parallax shifting.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba",
    "chromatic-edges"
  ],
  "params": [
    {
      "id": "density",
      "name": "Tile Density",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "rotation",
      "name": "Rotation Amount",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "chroma",
      "name": "Chromatic Edge",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "influence",
      "name": "Mouse Influence",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "mosaic",
    "crystal",
    "geometric",
    "triangular",
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "chromatic"
  ]
}
