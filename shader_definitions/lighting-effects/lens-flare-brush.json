      "id": "threshold"
    },
    {
      "name": "Intensity",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "id": "intensity"
    },
    {
      "name": "Stretch",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "id": "stretch"
    },
    {
      "name": "Color Shift",
      "type": "float",
      "default": 0.2,
      "min": 0,
      "max": 1,
      "id": "color_shift"
    }
  ],
  "features": [
    "mouse-driven"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}