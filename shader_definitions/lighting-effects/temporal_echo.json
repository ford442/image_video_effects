{
  "id": "temporal_echo",
  "name": "Temporal Echo",
  "url": "shaders/temporal_echo.wgsl",
  "description": "Multi-frame echo accumulation with hue-rotating trails, chromatic aberration on older echoes, depth-layered decay, and audio-reactive beat flash.",
  "tags": [
    "temporal",
    "echo",
    "trail",
    "hue",
    "chromatic",
    "audio",
    "depth"
  ],
  "features": [
    "temporal",
    "depth-aware",
    "audio-reactive"
  ],
  "params": [
    {
      "id": "decay_rate",
      "name": "Decay Rate",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "hue_shift_speed",
      "name": "Hue Shift Speed",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "chroma_spread",
      "name": "Chroma Spread",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    {
      "id": "depth_influence",
      "name": "Depth Influence",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ]
}
