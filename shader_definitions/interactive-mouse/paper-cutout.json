{
  "id": "paper-cutout",
  "name": "Paper Cutout",
  "url": "shaders/paper-cutout.wgsl",
  "description": "Quantizes the image into paper layers with drop shadows controlled by the mouse.",
  "params": [
    {
      "id": "layers",
      "name": "Layers",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "shadowDist",
      "name": "Shadow Dist",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "softness",
      "name": "Softness",
      "default": 0.1,
      "min": 0,
      "max": 1
    },
    {
      "id": "separation",
      "name": "Separation",
      "default": 0.2,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "upgraded-rgba",
    "audio-reactive",
    "depth-aware"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
