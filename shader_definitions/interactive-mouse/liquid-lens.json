{
  "id": "liquid-lens",
  "name": "Liquid Lens",
  "url": "shaders/liquid-lens.wgsl",
  "description": "Simulates a magnifying liquid lens at the mouse position with chromatic aberration.",
  "params": [
    {
      "id": "strength",
      "name": "Refraction",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "radius",
      "name": "Radius",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "abberation",
      "name": "Aberration",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "edge",
      "name": "Edge Shade",
      "default": 0.3,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "distortion",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
