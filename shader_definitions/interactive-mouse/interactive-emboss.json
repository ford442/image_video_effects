{
  "id": "interactive-emboss",
  "name": "Interactive Emboss",
  "url": "shaders/interactive-emboss.wgsl",
  "description": "Emboss effect where the light source follows the mouse cursor.",
  "params": [
    {
      "id": "strength",
      "name": "Strength",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "mix",
      "name": "Intensity",
      "default": 1,
      "min": 0,
      "max": 1
    },
    {
      "id": "colorMode",
      "name": "Color Mode",
      "default": 0,
      "min": 0,
      "max": 1,
      "labels": [
        "Gray",
        "Color"
      ]
    },
    {
      "id": "emboss_depth",
      "name": "Emboss Depth",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "Depth of emboss effect"
    }
  ],
  "features": [
    "mouse-driven",
    "upgraded-rgba",
    "audio-reactive",
    "depth-aware"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
