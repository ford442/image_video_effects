{
  "id": "virtual-lens",
  "name": "Virtual Lens",
  "url": "shaders/virtual-lens.wgsl",
  "description": "A virtual magnifying glass with alpha translucency blending. Single magnification displacement plus spectral tint via mix. Alpha driven by lens edge falloff and Fresnel reflectance with depth-aware attenuation.",
  "params": [
    {
      "id": "mag",
      "name": "Magnification",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "radius",
      "name": "Lens Radius",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "aberration",
      "name": "Aberration",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "softness",
      "name": "Edge Softness",
      "default": 0.2,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "chromatic-aberration",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
