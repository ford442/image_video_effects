{
  "id": "glass-bead-curtain",
  "name": "Glass Bead Curtain",
  "category": "interactive-mouse",
  "url": "shaders/glass-bead-curtain.wgsl",
  "description": "Physical glass bead curtain with Fresnel refraction, chromatic caustics, subsurface scattering, and bead-collision physics. Bass drives wind sway, mouse pushes beads aside, depth controls perspective bead size.",
  "params": [
    {
      "id": "size",
      "name": "Bead Size",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x",
      "description": "Relative bead size"
    },
    {
      "id": "refraction",
      "name": "Refraction",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y",
      "description": "Refraction strength"
    },
    {
      "id": "tension",
      "name": "Interact Tension",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "How strongly the curtain bends toward cursor motion"
    },
    {
      "id": "glass_density",
      "name": "Glass Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "Transmission strength through the bead field"
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba"
  ],
  "tags": [
    "glass",
    "beads",
    "iridescent",
    "refraction",
    "caustics",
    "fresnel",
    "audio-reactive",
    "depth-aware"
  ]
}
