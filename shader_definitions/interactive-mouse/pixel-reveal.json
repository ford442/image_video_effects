{
  "id": "pixel-reveal",
  "name": "Pixel Reveal",
  "url": "shaders/pixel-reveal.wgsl",
  "category": "interactive-mouse",
  "description": "Pixel sorting with threshold-based reveal and temporal noise accumulation. Revealed pixels decay back to hidden over time. Glitch chromatic separation on edges, scanline bands, film grain, and depth-controlled pixel perspective.",
  "params": [
    {
      "id": "pixelSize",
      "name": "Pixel Size",
      "default": 0.2,
      "min": 0,
      "max": 1
    },
    {
      "id": "radius",
      "name": "Radius",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "softness",
      "name": "Edge Softness",
      "default": 0.2,
      "min": 0,
      "max": 1
    },
    {
      "id": "decay_rate",
      "name": "Temporal Decay",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba"
  ],
  "tags": [
    "filter",
    "pixel-sort",
    "glitch",
    "scanlines",
    "film-grain",
    "chromatic",
    "temporal"
  ]
}
