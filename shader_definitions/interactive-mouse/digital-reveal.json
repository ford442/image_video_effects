      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "fade",
      "name": "Trail Fade",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "speed",
      "name": "Rain Speed",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
