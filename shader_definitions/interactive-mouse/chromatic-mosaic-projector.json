{
  "id": "chromatic-mosaic-projector",
  "name": "Chromatic Mosaic",
  "url": "shaders/chromatic-mosaic-projector.wgsl",
  "category": "image",
  "description": "Projects the image onto a reactive mosaic grid with chromatic aberration, audio-reactive cell pulsing, mouse gravity wells, click shockwaves, depth parallax, and temporal feedback trails.",
  "params": [
    {
      "id": "cells",
      "name": "Cell Count",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "spread",
      "name": "Light Spread",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "chroma",
      "name": "Aberration",
      "default": 0.5,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "tint",
      "name": "Light Tint",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "temporal",
    "depth-aware"
  ],
  "tags": [
    "filter",
    "image-processing",
    "mosaic",
    "chromatic",
    "audio-reactive",
    "interactive",
    "feedback"
  ]
}
