    {
      "id": "threshold",
      "name": "Edge Threshold",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "id": "glowRadius",
      "name": "Glow Radius",
      "default": 0.4,
      "min": 0,
      "max": 1
    },
    {
      "id": "intensity",
      "name": "Intensity",
      "default": 0.6,
      "min": 0,
      "max": 1
    },
    {
      "id": "colorCycle",
      "name": "Color Speed",
      "default": 0.3,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "depth-aware",
    "upgraded-rgba"
  ],
  "tags": [
    "edges",
