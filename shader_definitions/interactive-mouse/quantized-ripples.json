{
  "id": "quantized-ripples",
  "name": "Haptic Ripple Field",
  "url": "shaders/quantized-ripples.wgsl",
  "description": "Piezo-inspired ripple interference field with velocity-sensitive impulse strength, blended damping models, rough touch-texture modulation, and quantized color bands.",
  "params": [
    {
      "id": "stiffness",
      "name": "Surface Stiffness",
      "default": 0.45,
      "min": 0,
      "max": 1
    },
    {
      "id": "damping",
      "name": "Damping Ratio",
      "default": 0.35,
      "min": 0,
      "max": 1
    },
    {
      "id": "texture",
      "name": "Touch Texture",
      "default": 0.4,
      "min": 0,
      "max": 1
    },
    {
      "id": "decay_mode",
      "name": "Decay Mode",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "features": [
    "mouse-driven",
    "depth-aware",
    "haptic-response",
    "multi-touch-interference"
  ],
  "tags": [
    "filter",
    "image-processing",
    "haptic",
    "ripple",
    "posterize"
  ]
}
