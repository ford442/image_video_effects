      "name": "Cursor Drift",
      "default": 0.4,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "excitation_threshold",
      "name": "Excitation Threshold",
      "default": 0.3,
      "min": 0.0,
      "max": 1.0
    },
    {
      "id": "halation",
      "name": "Halation",
      "default": 0.45,
      "min": 0.0,
      "max": 1.0
    }
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "temporal",
    "depth-aware"
  ],
  "tags": [
