{
  "id": "sonar-reveal",
  "name": "Sonar Reveal",
  "url": "shaders/sonar-reveal.wgsl",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "audio-driven",
    "upgraded-rgba"
  ],
  "description": "Reveals the original image in a radius around the mouse, with a scanning radar ring. Reactive to audio.",
  "params": [
    {
      "name": "Reveal Size",
      "id": "size",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "name": "Ring Intensity",
      "id": "intensity",
      "default": 0.8,
      "min": 0,
      "max": 1
    },
    {
      "name": "Edge Softness",
      "id": "softness",
      "default": 0.2,
      "min": 0,
      "max": 1
    },
    {
      "name": "Color Mode",
      "id": "color",
      "default": 0,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "audio",
    "music",
    "reactive"
  ]
}
