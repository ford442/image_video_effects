{
  "id": "double-exposure",
  "name": "Double Exposure Warp",
  "url": "shaders/double-exposure.wgsl",
  "description": "Blends the image with a domain-warped, zoomed and rotated version of itself. Voronoi cellular ridges modulate the overlay intensity. Reacts to audio bass.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "name": "Zoom Level",
      "id": "zoom",
      "default": 0.3,
      "min": 0,
      "max": 1
    },
    {
      "name": "Rotation",
      "id": "rotation",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "name": "Opacity",
      "id": "opacity",
      "default": 0.6,
      "min": 0,
      "max": 1
    },
    {
      "name": "Warp Strength",
      "id": "warp",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "zoom",
    "overlay",
    "organic",
    "abstract"
  ]
}
