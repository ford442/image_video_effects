{
  "id": "anaglyph-3d",
  "name": "Anaglyph 3D",
  "url": "shaders/anaglyph-3d.wgsl",
  "category": "visual-effects",
  "description": "Red-cyan stereoscopic anaglyph from a single camera feed. The red channel is sampled at a leftward horizontal offset and cyan (G+B) at a rightward offset, creating the classic red/cyan 3D glasses effect. Separation widens with distance from the mouse focal point; a secondary ghost layer adds fringing depth. Bass pulses the split width; mids warm the left ghost; mouse controls the depth focal centre.",
  "tags": [
    "stereoscopic",
    "anaglyph",
    "3d",
    "chromatic",
    "audio-reactive",
    "mouse-driven"
  ],
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "separation",
      "name": "Stereo Separation",
      "default": 0.4,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.x"
    },
    {
      "id": "depthCurve",
      "name": "Depth Falloff",
      "default": 0.4,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.y"
    },
    {
      "id": "ghostStrength",
      "name": "Ghost Fringing",
      "default": 0.3,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.z"
    },
    {
      "id": "grain",
      "name": "Film Grain",
      "default": 0.2,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "mapping": "zoom_params.w"
    }
  ],
  "coordinate": 889
}
