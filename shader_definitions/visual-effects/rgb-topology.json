{
  "id": "rgb-topology",
  "name": "RGB Topology",
  "category": "visual-effects",
  "url": "shaders/rgb-topology.wgsl",
  "description": "Draws RGB contour lines from image luminance and depth, then blends them back over the source with neon topology glow.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "depth-aware"
  ],
  "tags": [
    "topology",
    "contour",
    "rgb",
    "depth-aware",
    "audio-reactive"
  ],
  "params": [
    {
      "id": "contour_density",
      "name": "Contour Density",
      "default": 0.4,
      "min": 0,
      "max": 1
    },
    {
      "id": "line_thickness",
      "name": "Line Thickness",
      "default": 0.22,
      "min": 0,
      "max": 1
    },
    {
      "id": "channel_separation",
      "name": "Channel Separation",
      "default": 0.35,
      "min": 0,
      "max": 1
    },
    {
      "id": "source_blend",
      "name": "Source Blend",
      "default": 0.4,
      "min": 0,
      "max": 1
    }
  ]
}
