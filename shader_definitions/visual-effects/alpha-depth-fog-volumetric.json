    { "id": "fogDensity", "name": "Fog Density", "type": "float", "default": 0.4, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "fogHeight", "name": "Fog Height", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "turbulence", "name": "Turbulence", "type": "float", "default": 0.3, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "colorTemp", "name": "Color Temperature", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 }
