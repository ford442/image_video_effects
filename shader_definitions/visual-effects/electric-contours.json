{
  "id": "electric-contours",
  "name": "Electric Contours",
  "category": "visual-effects",
  "url": "shaders/electric-contours.wgsl",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "field-line-tracing",
    "equipotential-surfaces",
    "dielectric-polarization",
    "corona-discharge"
  ],
  "description": "Electric field line tracing from charge distributions with equipotential surfaces and field line density. Dielectric boundary conditions with plasma-like glow, polarization colors, HDR bloom on high-field regions, ACES tone mapping, and corona discharge approximation.",
  "params": [
    {
      "id": "edge_threshold",
      "name": "Edge Threshold",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.x",
      "description": "Base threshold for edge detection"
    },
    {
      "id": "glow_intensity",
      "name": "Glow Intensity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.y",
      "description": "Intensity multiplier for the electric glow"
    },
    {
      "id": "field_density",
      "name": "Field Line Density",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.z",
      "description": "Density of field and equipotential lines"
    },
    {
      "id": "spark_speed",
      "name": "Spark Speed",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapping": "zoom_params.w",
      "description": "Speed of electric spark animation"
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "electric-field",
    "equipotential",
    "dielectric",
    "corona",
    "plasma-glow",
    "hdr-bloom",
    "aces-tone-mapping",
    "audio-reactive",
    "mouse-driven"
  ]
}
