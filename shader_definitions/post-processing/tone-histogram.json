    { "id": "saturation", "name": "Saturation", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "id": "psychedelic", "name": "Psychedelic Mode", "default": 0, "min": 0, "max": 1, "step": 1 }
