{
  "id": "static-reveal",
  "name": "Static Reveal",
  "url": "shaders/static-reveal.wgsl",
  "description": "The screen is covered in static noise. Scratch with the mouse to reveal the video underneath.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "audio-driven",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "decay",
      "name": "Regrowth Speed",
      "default": 0.01,
      "min": 0,
      "max": 0.1
    },
    {
      "id": "radius",
      "name": "Brush Size",
      "default": 0.3,
      "min": 0.05,
      "max": 0.5
    },
    {
      "id": "noise",
      "name": "Static Intensity",
      "default": 1,
      "min": 0,
      "max": 1
    },
    {
      "id": "noiseScale",
      "name": "Noise Scale",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "audio",
    "music",
    "reactive"
  ]
}
