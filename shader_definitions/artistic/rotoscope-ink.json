{
  "id": "rotoscope-ink",
  "name": "Rotoscope Ink",
  "category": "artistic",
  "url": "shaders/rotoscope-ink.wgsl",
  "description": "Posterizes the source frame into rotoscoped color blocks and animated ink outlines with cursor-boosted edge glow.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "edge-stylization"
  ],
  "tags": [
    "rotoscope",
    "ink",
    "posterize",
    "outline",
    "audio-reactive"
  ],
  "params": [
    {
      "id": "edge_threshold",
      "name": "Edge Threshold",
      "default": 0.32,
      "min": 0,
      "max": 1
    },
    {
      "id": "posterize_levels",
      "name": "Posterize Levels",
      "default": 0.45,
      "min": 0,
      "max": 1
    },
    {
      "id": "ink_density",
      "name": "Ink Density",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "shade_mix",
      "name": "Shade Mix",
      "default": 0.55,
      "min": 0,
      "max": 1
    }
  ]
}
