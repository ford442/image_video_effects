{
  "id": "encaustic-wax",
  "name": "Encaustic Wax",
  "description": "Simulates the translucent, textured look of hot wax painting. Mouse interaction melts the wax locally.",
  "url": "shaders/encaustic-wax.wgsl",
  "features": [
    "mouse-driven",
    "blur",
    "texture"
  ],
  "params": [
    {
      "id": "thickness",
      "name": "Wax Thickness",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "texture",
      "name": "Surface Texture",
      "default": 0.7,
      "min": 0,
      "max": 1
    },
    {
      "id": "radius",
      "name": "Melt Radius",
      "default": 0.2,
      "min": 0,
      "max": 0.5
    },
    {
      "id": "intensity",
      "name": "Melt Intensity",
      "default": 1,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}
