    { "id": "dryRate", "name": "Drying Rate", "type": "float", "default": 0.3, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "pigmentDeposit", "name": "Pigment Deposit", "type": "float", "default": 0.6, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "waterCapacity", "name": "Water Capacity", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.01 },
    { "id": "flowStrength", "name": "Flow Strength", "type": "float", "default": 0.4, "min": 0.0, "max": 1.0, "step": 0.01 }
