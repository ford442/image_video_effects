{
  "id": "interactive-zoom-blur",
  "name": "Interactive Zoom Blur",
  "url": "shaders/interactive-zoom-blur.wgsl",
  "description": "Radial zoom blur centered on the mouse cursor with audio-reactive intensity and chromatic aberration.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba"
  ],
  "params": [
    {
      "id": "strength",
      "name": "Blur Strength",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "samples",
      "name": "Quality",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "bias",
      "name": "Center Bias",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "aberration",
      "name": "Aberration",
      "default": 0.2,
      "min": 0,
      "max": 1
    }
  ],
  "tags": [
    "filter",
    "image-processing",
    "zoom",
    "radial",
    "blur",
    "chromatic"
  ]
}
