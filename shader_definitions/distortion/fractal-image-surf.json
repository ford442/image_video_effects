{
  "id": "fractal-image-surf",
  "name": "Fractal Image Surf",
  "url": "shaders/fractal-image-surf.wgsl",
  "category": "image",
  "description": "Maps the image onto a Julia Set fractal coordinate system, controlled by the mouse.",
  "params": [
    {
      "name": "Iterations",
      "type": "float",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "id": "iterations"
    },
    {
      "name": "Zoom",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "id": "zoom"
    },
    {
      "name": "Offset X",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "id": "offset_x"
    },
    {
      "name": "Offset Y",
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "id": "offset_y"
    }
  ],
  "features": [
    "mouse-driven"
  ],
  "tags": [
    "filter",
    "image-processing"
  ]
}