      "id": "burst_length",
      "name": "Burst Length",
      "default": 0.45,
      "min": 0,
      "max": 1
    },
    {
      "id": "sample_quality",
      "name": "Sample Quality",
      "default": 0.55,
      "min": 0,
      "max": 1
    },
    {
      "id": "spin",
      "name": "Spin",
      "default": 0.5,
      "min": 0,
      "max": 1
    },
    {
      "id": "chroma",
      "name": "Chroma",
      "default": 0.3,
      "min": 0,
      "max": 1
    }
  ]
