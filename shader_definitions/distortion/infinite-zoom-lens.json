{
  "id": "infinite-zoom-lens",
  "name": "Infinite Zoom Lens",
  "category": "distortion",
  "url": "shaders/infinite-zoom-lens.wgsl",
  "description": "A temporal zoom tunnel spirals the source image inward around the cursor and feeds the previous frame back into itself.",
  "features": [
    "mouse-driven",
    "audio-reactive",
    "upgraded-rgba",
    "temporal"
  ],
  "tags": [
    "zoom",
    "tunnel",
    "temporal",
    "spiral",
    "audio-reactive"
  ],
  "params": [
    {
      "id": "zoom_strength",
      "name": "Zoom Strength",
      "default": 0.45,
      "min": 0,
      "max": 1
    },
    {
      "id": "lens_radius",
      "name": "Lens Radius",
      "default": 0.35,
      "min": 0,
      "max": 1
    },
    {
      "id": "feedback_persistence",
      "name": "Feedback Persistence",
      "default": 0.65,
      "min": 0,
      "max": 1
    },
    {
      "id": "twist",
      "name": "Twist",
      "default": 0.5,
      "min": 0,
      "max": 1
    }
  ]
}
